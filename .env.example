# ──────────────────────────────────────────────────────────────────────────
# Test Case Creation Agent — environment configuration
# Copy to `.env` and fill in. All vars are read by app/.../settings.py
# ──────────────────────────────────────────────────────────────────────────

# --- Default provider: Azure OpenAI ---------------------------------------
LLM_PROVIDER=azure_openai
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Per-worker deployment / model names (the "settings slot" values)
LLM_PLANNER_MODEL=gpt-4o
LLM_PLANNER_TEMPERATURE=0.1
LLM_EXECUTOR_MODEL=gpt-4o
LLM_EXECUTOR_TEMPERATURE=0.5
LLM_REVIEWER_MODEL=gpt-4o
LLM_REVIEWER_TEMPERATURE=0.0

# --- Alternative providers (swap LLM_PROVIDER to use) ----------------------
# LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# LLM_PROVIDER=google
GOOGLE_API_KEY=

# --- Observability (LangSmith) --------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=test-case-creation

# --- Checkpointer ----------------------------------------------------------
# dev: in-memory; prod: postgres
CHECKPOINTER=memory
# POSTGRES_URL=postgresql://user:pass@localhost:5432/agent

# --- Guardrails ------------------------------------------------------------
INPUT_MAX_TOKENS=8000
INJECTION_BLOCK_THRESHOLD=0.85
CORRECTNESS_HARD_GATE=80
MAX_SELF_CORRECTIONS=2

# --- Dev convenience -------------------------------------------------------
# When true, build_llm() returns a deterministic offline stub model so the
# whole graph can run end-to-end without any API keys (useful for tests/demo).
LLM_OFFLINE_STUB=true

# ──────────────────────────────────────────────────────────────────────────
# Phase 4 — external integrations (ALL OPTIONAL).
# Leave blank to use the built-in graceful fallbacks (no live system needed).
# ──────────────────────────────────────────────────────────────────────────
# Requirement store (Neo4j OR Azure DevOps)
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
ADO_ORG_URL=
ADO_PROJECT=
ADO_PAT=
# Existing suite (MongoDB)
MONGODB_URI=
MONGODB_DB=qa
MONGODB_COLLECTION=test_cases
# Vector index (semantic dedupe)
VECTOR_BACKEND=
VECTOR_URL=
VECTOR_API_KEY=
# Test-management writes
TEST_MGMT_KIND=
TEST_MGMT_BASE_URL=
TEST_MGMT_TOKEN=
# Jira (webhook / fetch)
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_TOKEN=

# ──────────────────────────────────────────────────────────────────────────
# Phase 5 — governance
# ──────────────────────────────────────────────────────────────────────────
AGENT_VERSION=0.1.0
PROMPT_VERSION=2024-06-16
# Per-project feature flag (gradual rollout / instant rollback)
ENABLED_PROJECTS=               # CSV allowlist, e.g. DEMO-PROJ,TEAM-A
DEFAULT_PROJECT_ENABLED=true
FEATURE_FLAGS_FILE=             # optional JSON override {"PROJECT": true|false}

# ──────────────────────────────────────────────────────────────────────────
# Phase 6 — continuous improvement (JSONL stores)
# ──────────────────────────────────────────────────────────────────────────
FEEDBACK_PATH=data/feedback.jsonl
RUN_LOG_PATH=data/run_log.jsonl
